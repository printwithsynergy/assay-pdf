{
  "_comment": "Maps regex (case-insensitive) over pdfToolbox issue messages → GWG 2022 rule ID. Refined by inspecting actual pdfToolbox output during benchmark runs; missing patterns produce hits with rule_id=null which the scorer treats as known coverage gap, not engine failure.",
  "PDF/X-?4|conform.*PDF/X|output intent.*missing|not.*PDF/X": "R0001",
  "UserUnit|user unit": "R0002",
  "CropBox.*MediaBox|CropBox does not coincide": "R0003",
  "TrimBox.*missing|page (rotated|orientation)": "R0004",
  "empty page|no marks|TAC.*0": "R0005",
  "more than one page|multiple pages|page count": "R0006",
  "white.*overprint.*text|overprint.*white.*text": "R0007",
  "white.*overprint.*path|white.*fill.*overprint": "R0008",
  "black.*text.*overprint": "R0009",
  "black.*line.*overprint": "R0010",
  "small.*black.*DeviceGray.*overprint": "R0011",
  "thin.*black.*DeviceGray.*overprint": "R0012",
  "DeviceGray.*overprint": "R0013",
  "Courier|courier font": "R0014",
  "rich black|four-color black|cmyk.*black.*text": "R0015",
  "small.*white.*registration|small white text": "R0016",
  "small.*multi.?channel.*registration|multi-channel.*small text": "R0017",
  "thin.*white.*line": "R0018",
  "thin.*multi.?channel.*line": "R0019",
  "spot.*color.*count|too many spot|maximum.*spot": "R0020",
  "spot.*suffix|spot.*name.*equivalent": "R0021",
  "case.?sensitive.*spot|spot.*case": "R0022",
  "visually identical spot|spot.*duplicate": "R0023",
  "All.*registration|registration colour": "R0024",
  "ink coverage.*all separation|TAC.*all": "R0025",
  "ink coverage.*CMYK|TAC.*CMYK": "R0026",
  "DeviceRGB|RGB.*forbidden|early binding": "R0027",
  "image.*CalRGB|intermediate binding": "R0028",
  "image.*Indexed.*RGB|late binding": "R0029",
  "transparency.*blend|blend.*colour space": "R0030",
  "image resolution.*low|effective resolution.*below": "R0031",
  "1.?bit.*resolution|bitmap.*resolution": "R0032",
  "rasterized page|full page raster": "R0033",
  "OCProperties|optional content.*configs": "R0034",
  "output intent.*RGB|output intent.*not CMYK": "R0035",
  "hidden OCG|OCG.*hidden": "R0036",
  "scaling factor|viewing distance": "R0037",
  "processing step.*missing|GTS_Proc.*required": "R1001",
  "creasing.*required|cut.*missing.*folding carton": "R1002"
}
